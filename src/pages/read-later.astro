---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Read Later - RSS Reader">
  <Header />
  <main class="container rl-page">

    <!-- Token setup -->
    <details id="token-setup" class="rl-token-setup">
      <summary>⚙️ Setup</summary>
      <div class="rl-token-form">
        <p>Enter your <code>READ_LATER_TOKEN</code> once to enable saving from this device.</p>
        <div class="rl-token-row">
          <input type="password" id="token-input" placeholder="Paste token here" autocomplete="off" />
          <button id="token-save-btn" class="btn-primary">Save token</button>
          <button id="token-clear-btn" class="btn-secondary">Clear</button>
        </div>
        <p id="token-status" class="rl-token-status"></p>

        <hr class="rl-divider" />
        <h4>Bookmarklet</h4>
        <p>Drag this to your bookmarks bar to save any page with one click:</p>
        <a id="bookmarklet-link" href="#" class="rl-bookmarklet">📌 Read Later</a>
        <p class="rl-hint">The bookmarklet URL updates automatically once your token is saved.</p>

        <h4>iOS Shortcut</h4>
        <ol class="rl-instructions">
          <li>Open the Shortcuts app and tap <strong>+</strong></li>
          <li>Add action: <strong>Get Contents of URL</strong></li>
          <li>Set URL to: <code id="api-url-display">https://rss-pardoena.netlify.app/.netlify/functions/read-later</code> <button id="copy-api-url" class="copy-url-btn" aria-label="Copy URL" title="Copy URL">&#x1F4CB;</button></li>
          <li>Method: <strong>POST</strong></li>
          <li>Headers: <code>Content-Type: application/json</code>, <code>Authorization: Bearer YOUR_TOKEN</code></li>
          <li>Body: <code>&#123;"url":"&#123;Shortcut Input&#125;"&#125;</code></li>
          <li>Enable <strong>Show in Share Sheet</strong> for URLs</li>
        </ol>
      </div>
    </details>

    <!-- Add URL form -->
    <section class="rl-add">
      <form id="add-form" class="rl-add-form">
        <input type="url" id="url-input" placeholder="https://..." required class="rl-url-input" />
        <button type="submit" class="btn-primary">Save</button>
      </form>
      <p id="add-feedback" class="rl-feedback" aria-live="polite"></p>
    </section>

    <!-- Queue header -->
    <div class="rl-header">
      <h1>Read Later <span id="queue-count" class="rl-count"></span></h1>
    </div>

    <!-- States -->
    <p id="rl-loading" class="rl-state">Loading…</p>
    <p id="rl-empty" class="rl-state" hidden>Your queue is empty. Save something to read later!</p>
    <p id="rl-error" class="rl-state rl-state-error" hidden>Could not load queue. Check your token in Setup.</p>

    <!-- Items list -->
    <ul id="rl-list" class="rl-list" hidden></ul>

    <!-- Pagination -->
    <div id="rl-more-container" hidden>
      <button id="rl-more-btn" class="btn-secondary rl-more-btn">Show more</button>
    </div>

    <!-- Archive link -->
    <p id="rl-archive-link" class="rl-archive-link" hidden>
      <a href="/read-later/archive">View archive</a>
    </p>

  </main>
</Layout>

<style>
  .rl-page { max-width: 720px; margin-inline: auto; padding-block: var(--space-lg); }

  .rl-token-setup {
    margin-bottom: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-md);
  }
  .rl-token-setup summary { cursor: pointer; font-weight: 500; user-select: none; }
  .rl-token-form { margin-top: var(--space-md); }
  .rl-token-row { display: flex; gap: var(--space-sm); flex-wrap: wrap; margin-block: var(--space-sm); }
  .rl-token-row input { flex: 1; min-width: 200px; padding: var(--space-sm); border: 1px solid var(--color-border); border-radius: 4px; background: var(--color-bg); color: var(--color-text); font-family: monospace; }
  .rl-token-status { font-size: var(--font-size-sm); margin: 0; }
  .rl-divider { border: none; border-top: 1px solid var(--color-border); margin-block: var(--space-md); }
  .rl-bookmarklet { display: inline-block; padding: var(--space-xs) var(--space-sm); background: var(--color-accent); color: white; border-radius: 4px; text-decoration: none; font-size: var(--font-size-sm); cursor: pointer; }
  .rl-hint { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
  .rl-instructions { font-size: var(--font-size-sm); color: var(--color-text-secondary); padding-left: var(--space-lg); }
  .rl-instructions li { margin-bottom: var(--space-xs); }
  .rl-instructions code { background: var(--color-bg-secondary); padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.85em; }
  .copy-url-btn { background: none; border: none; cursor: pointer; padding: 0 0.25em; font-size: 1em; vertical-align: middle; opacity: 0.6; }
  .copy-url-btn:hover { opacity: 1; }

  .rl-add { margin-bottom: var(--space-lg); }
  .rl-add-form { display: flex; gap: var(--space-sm); }
  .rl-url-input { flex: 1; padding: var(--space-sm) var(--space-md); border: 1px solid var(--color-border); border-radius: 4px; background: var(--color-bg); color: var(--color-text); font-size: var(--font-size-sm); }
  .rl-feedback { font-size: var(--font-size-sm); margin-top: var(--space-xs); min-height: 1.4em; }
  .rl-feedback.success { color: #48bb78; }
  .rl-feedback.duplicate { color: var(--color-accent); }
  .rl-feedback.error { color: #e53e3e; }

  .rl-header { display: flex; align-items: baseline; gap: var(--space-sm); margin-bottom: var(--space-md); }
  .rl-count { font-size: var(--font-size-sm); color: var(--color-text-secondary); font-weight: normal; }

  .rl-state { text-align: center; padding: var(--space-xl); color: var(--color-text-secondary); }
  .rl-state-error { color: #e53e3e; }

  .rl-list { list-style: none; padding: 0; margin: 0; }

  .rl-more-btn { display: block; width: 100%; margin-top: var(--space-md); }
  .rl-archive-link { text-align: center; margin-top: var(--space-xl); font-size: var(--font-size-sm); color: var(--color-text-secondary); }

  /* Item card styles */
  :global(.rl-item) {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    transition: opacity 0.3s, transform 0.3s;
  }
  :global(.rl-item:last-child) { border-bottom: none; }
  :global(.rl-thumb-wrap) { position: relative; flex-shrink: 0; width: 120px; height: 67px; border-radius: 4px; overflow: hidden; background: var(--color-bg-secondary); }
  :global(.rl-thumb) { width: 100%; height: 100%; object-fit: cover; }
  :global(.rl-yt-badge) { position: absolute; bottom: 4px; left: 4px; background: #ff0000; color: white; font-size: 0.65rem; font-weight: 700; padding: 1px 4px; border-radius: 2px; }
  :global(.rl-info) { flex: 1; min-width: 0; }
  :global(.rl-title) { font-size: var(--font-size-base); font-weight: 500; margin-bottom: var(--space-xs); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  :global(.rl-title a) { color: var(--color-text); text-decoration: none; }
  :global(.rl-title a:hover) { color: var(--color-accent); }
  :global(.rl-desc) { font-size: var(--font-size-sm); color: var(--color-text-secondary); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: var(--space-xs); }
  :global(.rl-meta) { font-size: 0.75rem; color: var(--color-text-secondary); }
  :global(.rl-actions) { display: flex; flex-direction: column; gap: var(--space-xs); flex-shrink: 0; justify-content: center; }
  :global(.rl-btn) { background: none; border: 1px solid var(--color-border); border-radius: 4px; padding: var(--space-xs) var(--space-sm); cursor: pointer; font-size: var(--font-size-sm); color: var(--color-text-secondary); white-space: nowrap; }
  :global(.rl-btn:hover) { background: var(--color-bg-secondary); }
  :global(.rl-btn-read:hover) { border-color: #48bb78; color: #48bb78; }
  :global(.rl-btn-delete:hover) { border-color: #e53e3e; color: #e53e3e; }

  @media (max-width: 480px) {
    :global(.rl-thumb-wrap) { width: 80px; height: 45px; }
    :global(.rl-desc) { display: none; }
    :global(.rl-actions) { flex-direction: row; }
  }
</style>

<script>
  const SITE_URL = 'https://rss-pardoena.netlify.app';
  const API = `${SITE_URL}/.netlify/functions/read-later`;
  const TOKEN_KEY = 'rl-token';

  // ── Copy API URL button ──────────────────────────────────────────────────────
  document.getElementById('copy-api-url')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const url = (document.getElementById('api-url-display') as HTMLElement).textContent || '';
    await navigator.clipboard.writeText(url);
    btn.textContent = '✓';
    setTimeout(() => { btn.textContent = '📋'; }, 1500);
  });

  // ── Token management ────────────────────────────────────────────────────────
  const tokenInput = document.getElementById('token-input') as HTMLInputElement;
  const tokenSaveBtn = document.getElementById('token-save-btn')!;
  const tokenClearBtn = document.getElementById('token-clear-btn')!;
  const tokenStatus = document.getElementById('token-status')!;
  const bookmarkletLink = document.getElementById('bookmarklet-link') as HTMLAnchorElement;
  const setupDetails = document.getElementById('token-setup') as HTMLDetailsElement;

  function getToken(): string { return localStorage.getItem(TOKEN_KEY) || ''; }

  function updateBookmarklet(token: string) {
    const code = `(function(){
      var t=fetch('${API}',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer ${token}'},body:JSON.stringify({url:location.href,title:document.title})})
      .then(r=>r.json()).then(d=>{
        var s=document.createElement('div');
        s.style='position:fixed;top:16px;right:16px;z-index:99999;padding:10px 16px;border-radius:6px;font:14px/1.4 sans-serif;color:#fff;background:'+(d.message==='Already saved'?'#3182ce':'#48bb78');
        s.textContent=d.message==='Already saved'?'Already saved!':'Saved!';
        document.body.appendChild(s);setTimeout(()=>s.remove(),2000);
      }).catch(()=>{
        var s=document.createElement('div');
        s.style='position:fixed;top:16px;right:16px;z-index:99999;padding:10px 16px;border-radius:6px;font:14px/1.4 sans-serif;color:#fff;background:#e53e3e';
        s.textContent='Failed to save';document.body.appendChild(s);setTimeout(()=>s.remove(),2000);
      });
    })();`;
    bookmarkletLink.href = 'javascript:void' + encodeURIComponent(`(${code.replace(/\s+/g,' ')})`) + '';
    bookmarkletLink.href = `javascript:void(${encodeURIComponent(code.replace(/\s+/g, ' '))})`;
  }

  function initToken() {
    const saved = getToken();
    if (saved) {
      tokenInput.value = saved;
      tokenStatus.textContent = '✓ Token saved';
      tokenStatus.style.color = '#48bb78';
      updateBookmarklet(saved);
      setupDetails.open = false;
    }
  }

  tokenSaveBtn.addEventListener('click', () => {
    const val = tokenInput.value.trim();
    if (!val) { tokenStatus.textContent = 'Please enter a token'; return; }
    localStorage.setItem(TOKEN_KEY, val);
    tokenStatus.textContent = '✓ Token saved';
    tokenStatus.style.color = '#48bb78';
    updateBookmarklet(val);
    setupDetails.open = false;
    loadQueue();
  });

  tokenClearBtn.addEventListener('click', () => {
    localStorage.removeItem(TOKEN_KEY);
    tokenInput.value = '';
    tokenStatus.textContent = 'Token cleared';
    tokenStatus.style.color = '';
  });

  initToken();

  // ── Add form ─────────────────────────────────────────────────────────────────
  const addForm = document.getElementById('add-form') as HTMLFormElement;
  const urlInput = document.getElementById('url-input') as HTMLInputElement;
  const feedback = document.getElementById('add-feedback')!;

  addForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const url = urlInput.value.trim();
    const token = getToken();
    if (!token) { showFeedback('Enter your token in Setup first', 'error'); return; }

    showFeedback('Saving…', '');
    try {
      const res = await fetch(API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ url }),
      });
      const data = await res.json();
      if (res.status === 201) {
        showFeedback(`Saved: ${data.title}`, 'success');
        urlInput.value = '';
        setTimeout(() => loadQueue(), 400);
      } else if (res.status === 200) {
        showFeedback('Already in your queue!', 'duplicate');
      } else {
        showFeedback(data.error || 'Failed to save', 'error');
      }
    } catch {
      showFeedback('Network error', 'error');
    }
  });

  function showFeedback(msg: string, type: string) {
    feedback.textContent = msg;
    feedback.className = `rl-feedback${type ? ' ' + type : ''}`;
  }

  // ── Queue loading ─────────────────────────────────────────────────────────────
  const loadingEl = document.getElementById('rl-loading')!;
  const emptyEl = document.getElementById('rl-empty')!;
  const errorEl = document.getElementById('rl-error')!;
  const listEl = document.getElementById('rl-list')!;
  const moreContainer = document.getElementById('rl-more-container')!;
  const moreBtn = document.getElementById('rl-more-btn')!;
  const archiveLink = document.getElementById('rl-archive-link')!;
  const countEl = document.getElementById('queue-count')!;

  let lastAddedAt = '';

  async function loadQueue(append = false) {
    const token = getToken();
    if (!token) {
      loadingEl.hidden = true;
      errorEl.hidden = false;
      return;
    }

    if (!append) {
      loadingEl.hidden = false;
      listEl.hidden = true;
      emptyEl.hidden = true;
      errorEl.hidden = true;
      moreContainer.hidden = true;
    }

    try {
      let url = `${API}?token=${encodeURIComponent(token)}`;
      if (append && lastAddedAt) url += `&before=${encodeURIComponent(lastAddedAt)}`;

      const res = await fetch(url);
      if (!res.ok) throw new Error(`${res.status}`);
      const data = await res.json();

      loadingEl.hidden = true;

      if (!append && data.items.length === 0) {
        emptyEl.hidden = false;
        archiveLink.hidden = false;
        return;
      }

      listEl.hidden = false;
      if (!append) listEl.innerHTML = '';

      data.items.forEach((item: any) => {
        lastAddedAt = item.added_at;
        listEl.appendChild(buildCard(item, false));
      });

      if (!append) countEl.textContent = `(${data.items.length}${data.has_more ? '+' : ''})`;
      moreContainer.hidden = !data.has_more;
      archiveLink.hidden = false;
    } catch {
      loadingEl.hidden = true;
      if (!append) errorEl.hidden = false;
    }
  }

  moreBtn.addEventListener('click', () => loadQueue(true));

  function buildCard(item: any, isArchive: boolean): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'rl-item';
    li.dataset.id = item.id;

    const isYt = item.source_type === 'youtube';
    const domain = (() => { try { return new URL(item.url).hostname; } catch { return item.url; } })();
    const date = new Date(isArchive ? item.read_at : item.added_at);
    const dateStr = date.toLocaleDateString('nl-BE', { day: 'numeric', month: 'short', year: 'numeric' });

    li.innerHTML = `
      ${item.image_url ? `
        <div class="rl-thumb-wrap">
          <img class="rl-thumb" src="${escHtml(item.image_url)}" alt="" loading="lazy" />
          ${isYt ? '<span class="rl-yt-badge">▶ YouTube</span>' : ''}
        </div>` : ''}
      <div class="rl-info">
        <div class="rl-title"><a href="${escHtml(item.url)}" target="_blank" rel="noopener noreferrer">${escHtml(item.title || item.url)}</a></div>
        ${item.description ? `<p class="rl-desc">${escHtml(item.description)}</p>` : ''}
        <div class="rl-meta">${escHtml(item.yt_channel ? item.yt_channel + ' · ' : '')}${escHtml(domain)} · ${dateStr}</div>
      </div>
      <div class="rl-actions">
        ${isArchive
          ? `<button class="rl-btn rl-btn-restore" aria-label="Restore">↩ Restore</button>`
          : `<button class="rl-btn rl-btn-read" aria-label="Mark as read">✓ Done</button>`}
        <button class="rl-btn rl-btn-delete" aria-label="Delete">✕</button>
      </div>`;

    li.querySelector('.rl-btn-read, .rl-btn-restore')?.addEventListener('click', () => markRead(li, item.id));
    li.querySelector('.rl-btn-delete')?.addEventListener('click', () => deleteItem(li, item.id));

    return li;
  }

  async function apiItem(method: string, id: number) {
    const token = getToken();
    return fetch(`${SITE_URL}/.netlify/functions/read-later-item`, {
      method,
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify({ id }),
    });
  }

  async function markRead(li: HTMLLIElement, id: number) {
    li.style.opacity = '0';
    li.style.transform = 'translateX(20px)';
    await apiItem('PATCH', id);
    setTimeout(() => li.remove(), 300);
  }

  async function deleteItem(li: HTMLLIElement, id: number) {
    if (!confirm('Remove this item?')) return;
    li.style.opacity = '0';
    li.style.transform = 'translateX(20px)';
    await apiItem('DELETE', id);
    setTimeout(() => li.remove(), 300);
  }

  function escHtml(str: string): string {
    return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  loadQueue();
</script>
